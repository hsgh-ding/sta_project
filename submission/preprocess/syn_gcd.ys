# GCD synth → ASAP7 RVT TT
# Usage: PATH=/home/ding/local/usr/bin:$PATH TMPDIR=/mnt/f/reasonix yosys syn_gcd.ys

read_liberty -lib /mnt/f/reasonix/OpenROAD-flow-scripts/flow/platforms/asap7/lib/asap7sc7p5t_SEQ_RVT_TT_nldm_201020.lib
read_verilog /mnt/f/reasonix/OpenROAD-flow-scripts/flow/designs/src/gcd/gcd.v

